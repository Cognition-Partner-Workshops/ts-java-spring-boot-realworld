<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Selenium Smoke Tests">
    
    <listeners>
        <listener class-name="io.spring.selenium.listeners.TestListener"/>
    </listeners>
    
    <test name="Setup Verification">
        <classes>
            <class name="io.spring.selenium.tests.SeleniumSetupTest"/>
        </classes>
    </test>
    
    <test name="Home Page Smoke Tests">
        <classes>
            <class name="io.spring.selenium.tests.HomePageTest">
                <methods>
                    <include name="testHomePageLoads"/>
                    <include name="testHomePageShowsSignInSignUpWhenLoggedOut"/>
                    <include name="testHomePageShowsNewPostAndSettingsWhenLoggedIn"/>
                </methods>
            </class>
        </classes>
    </test>
    
    <test name="User Registration Smoke Tests">
        <classes>
            <class name="io.spring.selenium.tests.UserRegistrationTest">
                <methods>
                    <include name="testRegisterPageLoads"/>
                    <include name="testSuccessfulRegistration"/>
                </methods>
            </class>
        </classes>
    </test>
    
    <test name="User Login Smoke Tests">
        <classes>
            <class name="io.spring.selenium.tests.UserLoginTest">
                <methods>
                    <include name="testLoginPageLoads"/>
                    <include name="testSuccessfulLogin"/>
                </methods>
            </class>
        </classes>
    </test>
    
    <test name="Article Smoke Tests">
        <classes>
            <class name="io.spring.selenium.tests.ArticleTest">
                <methods>
                    <include name="testEditorPageLoads"/>
                    <include name="testCreateArticle"/>
                </methods>
            </class>
        </classes>
    </test>
    
    <test name="Comment Smoke Tests">
        <classes>
            <class name="io.spring.selenium.tests.CommentTest">
                <methods>
                    <include name="testCommentFormDisplayedOnArticle"/>
                </methods>
            </class>
        </classes>
    </test>
    
    <test name="Profile Smoke Tests">
        <classes>
            <class name="io.spring.selenium.tests.ProfileTest">
                <methods>
                    <include name="testViewOwnProfile"/>
                </methods>
            </class>
        </classes>
    </test>
    
    <test name="Settings Smoke Tests">
        <classes>
            <class name="io.spring.selenium.tests.SettingsTest">
                <methods>
                    <include name="testSettingsPageLoads"/>
                </methods>
            </class>
        </classes>
    </test>
    
</suite>
