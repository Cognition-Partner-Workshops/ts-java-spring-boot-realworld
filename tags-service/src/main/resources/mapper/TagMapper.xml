<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="io.spring.tags.infrastructure.mybatis.mapper.TagMapper">
    <insert id="insert">
        insert into tags (id, name) values (#{tag.id}, #{tag.name})
    </insert>

    <select id="findById" resultType="io.spring.tags.core.Tag">
        select id, name from tags where id = #{id}
    </select>

    <select id="findByName" resultType="io.spring.tags.core.Tag">
        select id, name from tags where name = #{name}
    </select>

    <select id="findAll" resultType="io.spring.tags.core.Tag">
        select id, name from tags
    </select>

    <delete id="delete">
        delete from tags where id = #{id}
    </delete>
</mapper>
